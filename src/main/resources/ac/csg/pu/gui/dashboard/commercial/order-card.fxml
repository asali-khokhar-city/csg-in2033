<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ac.csg.pu.gui.dashboard.commercial.OrderCardController"
      spacing="8"
      styleClass="panel"
      style="-fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 5, 0, 0, 2);">

    <!-- Header row: status + date -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="order-status"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="dateLabel"   style="-fx-font-size:12px; -fx-text-fill:#7a8faa;"/>
    </HBox>

    <!-- Total -->
    <Label fx:id="totalLabel" styleClass="new-price"/>

    <!-- Toggle button -->
    <Button fx:id="toggleButton" text="▶  View Items"
            style="-fx-background-color: transparent; -fx-text-fill: #1976d2; -fx-font-weight:bold; -fx-cursor:hand; -fx-padding:0; -fx-font-size:12px;"/>

    <!-- Expandable section -->
    <VBox fx:id="detailsBox" spacing="6" visible="false" managed="false"
          style="-fx-background-color: #f8f9fd; -fx-padding: 8; -fx-border-color: #dde3ee; -fx-border-radius:6; -fx-background-radius:6;">
        <Label fx:id="addressLabel" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
        <VBox fx:id="itemsBox" spacing="3"/>
    </VBox>

</VBox>
