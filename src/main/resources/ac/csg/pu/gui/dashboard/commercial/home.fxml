<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="ac.csg.pu.gui.dashboard.commercial.HomeController"
           stylesheets="@../dashboard.css"
           styleClass="root"
           fx:id="root">

    <VBox spacing="0" alignment="TOP_CENTER">

        <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="16" prefHeight="60">
            <Label text="IPOS" styleClass="nav-logo"/>
            <Label text="PU"   styleClass="nav-logo-accent"/>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Search products or promotions..."
                       styleClass="search-field"/>

            <Region HBox.hgrow="ALWAYS"/>

            <StackPane>
                <Button text="🛒  Cart" onAction="#toggleCart" styleClass="nav-button-primary"/>
                <Label fx:id="cartBadge"
                       text="0"
                       visible="false"
                       style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 2 5 2 5; -fx-min-width: 18; -fx-alignment: center;"
                       StackPane.alignment="TOP_RIGHT"/>
            </StackPane>

            <Button text="📦  Orders" onAction="#checkOrders" styleClass="nav-button"/>
            <Button text="Logout"     onAction="#logout"      styleClass="nav-button"/>
        </HBox>

        <!-- focusTraversable=false prevents JavaFX auto-scrolling to the focused node after a button click -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" focusTraversable="false"
                    style="-fx-background-color: #f0f2f5; -fx-border-color: transparent;">

            <VBox spacing="18" focusTraversable="false"
                  style="-fx-background-color: #f0f2f5; -fx-padding: 20 28 20 28;">

                <Label fx:id="errorLabel" styleClass="error"/>

                <Label text="🏷  Current Promotions" styleClass="section-heading"/>
                <VBox fx:id="promotionsBox" spacing="16" focusTraversable="false"/>

                <Label text="🛍  All Products" styleClass="section-heading"/>
                <TilePane fx:id="productTilePane"
                          hgap="16" vgap="16"
                          prefColumns="4"
                          focusTraversable="false"
                          style="-fx-background-color: transparent;"/>

            </VBox>
        </ScrollPane>
    </VBox>

    <Rectangle fx:id="cartOverlay"
               fill="rgba(0,0,0,0.45)"
               visible="false"/>

    <fx:include source="cart-sidebar.fxml"
                fx:id="cartSidebar"
                StackPane.alignment="CENTER_RIGHT"/>

</StackPane>
